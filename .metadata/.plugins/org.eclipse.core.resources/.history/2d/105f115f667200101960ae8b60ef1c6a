package sec01.exam03;

public class A {
	// 인스턴스 멤버 ,메소드
	int field1;
	void method1() {}
	
	// 정적 멤버 ,메소드
	static int field2;
	static void method2() {}
	
	// 중첩 클래스
	class B{
		void method() {
			field1 = 10;
			method1();
			field2 = 20;
			method2();
		}
	}
	
	static class C{
		void method2() {
			field1 = 30;
			method1();
			field2 = 40;
			method2();
		}
	}
	
	
}
