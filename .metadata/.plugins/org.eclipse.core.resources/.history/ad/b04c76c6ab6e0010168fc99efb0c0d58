<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<%@ page import="java.sql.*, javax.sql.*" %>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>회원가입</title>
<!-- Bootstrap CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-5">
    <h2 class="mb-4 text-center">회원가입 화면</h2>
    <form method="get" class="border p-4 bg-white shadow-sm rounded">
        <div class="mb-3">
            <label class="form-label">아이디</label>
            <input type="text" name="member_id" class="form-control"/>
        </div>
        <div class="mb-3">
            <label class="form-label">비밀번호</label>
            <input type="password" name="member_pw" class="form-control"/>
        </div>
        <div class="mb-3">
            <label class="form-label">이름</label>
            <input type="text" name="member_name" class="form-control"/>
        </div>
        <div class="mb-3">
            <label class="form-label">전화번호</label>
            <input type="text" name="member_number" class="form-control"/>
        </div>
        <div class="mb-3">
            <label class="form-label">이메일</label>
            <input type="text" name="member_email" class="form-control"/>
        </div>
        <div class="d-flex justify-content-between">
            <input type="submit" name="action" value="확인" class="btn btn-success" />
            <input type="submit" name="action" value="삭제" class="btn btn-danger" />
            <input type="submit" name="action" value="조회" class="btn btn-primary" />
        </div>
    </form>

<%
String member_id = request.getParameter("member_id");
String member_pw = request.getParameter("member_pw");
String member_name = request.getParameter("member_name");
String member_number = request.getParameter("member_number");
String member_email = request.getParameter("member_email");
String action = request.getParameter("action");
String sql = "";

Connection conn = null;
Statement stmt = null;
ResultSet rs = null;

try {
    Class.forName("com.mysql.cj.jdbc.Driver");
    conn = DriverManager.getConnection("jdbc:mysql://localhost:3305/Member", "root", "1234");
    stmt = conn.createStatement();

    if (member_id != null && !"".equals(member_id)) {
        if ("확인".equals(action)) {
            sql = String.format("INSERT INTO member_0801(member_id,member_pw,member_name,member_number,member_email) VALUES('%s','%s','%s','%s','%s')",
                    member_id, member_pw, member_name, member_number, member_email);
            stmt.executeUpdate(sql);
        } else if ("삭제".equals(action)) {
            sql = String.format("DELETE FROM member_0801 WHERE member_id = '%s'", member_id);
            stmt.executeUpdate(sql);
        } else if ("조회".equals(action)) {
            sql = String.format("SELECT * FROM member_0801 WHERE member_id = '%s'", member_id); // ← 따옴표 누락 수정
            rs = stmt.executeQuery(sql);
        }
    }

    if (rs == null) {
        rs = stmt.executeQuery("SELECT * FROM member_0801");
    }
%>

    <h3 class="mt-5">회원 목록</h3>
    <table class="table table-bordered table-striped mt-3">
        <thead class="table-dark">
            <tr>
                <th>아이디</th>
                <th>비밀번호</th>
                <th>이름</th>
                <th>전화번호</th>
                <th>이메일</th>
            </tr>
        </thead>
        <tbody>
        <% while (rs.next()) { %>
            <tr>
                <td><%= rs.getString("member_id") %></td>
                <td><%= rs.getString("member_pw") %></td>
                <td><%= rs.getString("member_name") %></td>
                <td><%= rs.getString("member_number") %></td>
                <td><%= rs.getString("member_email") %></td>
            </tr>
        <% } %>
        </tbody>
    </table>

<%
} catch (SQLException e) {
    out.println("<div class='alert alert-danger mt-4'>데이터베이스 오류: " + e.getMessage() + "</div>");
} catch (ClassNotFoundException e) {
    out.println("<div class='alert alert-warning mt-4'>드라이버를 찾을 수 없습니다: " + e.getMessage() + "</div>");
} finally {
    try {
        if (rs != null) rs.close();
        if (stmt != null) stmt.close();
        if (conn != null) conn.close();
    } catch (SQLException e) {
        out.println("<div class='alert alert-warning mt-4'>리소스를 닫는 도중 오류 발생: " + e.getMessage() + "</div>");
    }
}
%>
</div>
</body>
</html>
