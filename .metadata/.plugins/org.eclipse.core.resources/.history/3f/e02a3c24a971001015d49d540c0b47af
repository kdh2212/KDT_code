package dp.decorator;

public class Main {
	public static long fac2(long num) {
		if(num == 0) {
			return 1;
		}else {
			return fac2(num - 1);
		}
	}

	public static long fac(long num) {
		long res = 1;
		for(long i=1; i <= num; i++) {
			res *= i;
		}
		return res;
	}
	public static void main(String[] args) {
		System.out.println(fac(5));
		System.out.println(fac2(5));
	}

}
